<mxfile host="app.diagrams.net" modified="2026-03-29T17:15:00.000Z" agent="Codex" version="24.7.17" editor="draw.io">
  <diagram id="scrabble-part3-architecture" name="Scrabble Architecture">
    <mxGraphModel dx="1820" dy="1120" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2300" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Scrabble Part 3 Architecture" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f4f4f4;strokeColor=#111111;fontSize=24;fontStyle=1;fontColor=#111111;align=left;verticalAlign=middle;spacingLeft=16;" vertex="1" parent="1">
          <mxGeometry x="60" y="20" width="880" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Current layout of the JavaFX game, shared scoring and solver engine, local stress tools, and final packaging path" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#666666;fontSize=14;fontColor=#222222;align=left;verticalAlign=middle;spacingLeft=16;" vertex="1" parent="1">
          <mxGeometry x="60" y="74" width="1500" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="headerPrograms" value="Programs" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d9d9d9;strokeColor=#333333;fontSize=18;fontStyle=1;fontColor=#111111;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="130" width="400" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="headerMatch" value="Match Flow" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dcecff;strokeColor=#335c85;fontSize=18;fontStyle=1;fontColor=#111111;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="560" y="130" width="400" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="headerLogic" value="Shared Logic" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ece7d8;strokeColor=#6b5f3a;fontSize=18;fontStyle=1;fontColor=#111111;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1060" y="130" width="480" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="headerOutputs" value="Outputs And Packaging" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0e1d8;strokeColor=#7a4d33;fontSize=18;fontStyle=1;fontColor=#111111;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1640" y="130" width="500" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="uiApp" value="Scrabble.java + PlacementBuffer&#xa;JavaFX entry point&#xa;renders the board, rack, scores, controls, and history&#xa;collects staged placements, blank choices, passes, and exchanges" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8f8f8;strokeColor=#333333;fontSize=13;fontColor=#111111;align=left;verticalAlign=top;spacingTop=10;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="190" width="400" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="cliTools" value="Scorechecker + Solver + input parsers&#xa;BoardParser, SolverInputParser, CompatibilityChecker, and MoveExtractor&#xa;read repeated prompt cases from stdin&#xa;print scorer output or the best move + solution board" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8f8f8;strokeColor=#333333;fontSize=13;fontColor=#111111;align=left;verticalAlign=top;spacingTop=10;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="420" width="400" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="selfPlay" value="ScrabbleSelfPlay&#xa;local solver-vs-solver harness&#xa;reuses the backend, logging, and move auditing&#xa;stress-tests constrained dictionaries and long batches" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8f8f8;strokeColor=#333333;fontSize=13;fontColor=#111111;align=left;verticalAlign=top;spacingTop=10;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="650" width="400" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="gameCore" value="ScrabbleGame&#xa;owns mutable match state&#xa;handles human moves, computer turns, passes, exchanges, and endgame scoring&#xa;ends after six consecutive scoreless turns&#xa;opens the standard board from the filesystem first, then bundled resources" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eef6ff;strokeColor=#335c85;fontSize=13;fontColor=#111111;align=left;verticalAlign=top;spacingTop=10;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="190" width="400" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="stateBox" value="ScrabblePlayer + RackState + TileBag&#xa;player racks, scores, tile draws, and exchanges&#xa;standard games start with filled seven-tile racks" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eef6ff;strokeColor=#335c85;fontSize=13;fontColor=#111111;align=left;verticalAlign=top;spacingTop=10;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="430" width="400" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="snapshotBox" value="GameSnapshot + TurnRecord + TurnActor + TurnType&#xa;immutable view for UI refreshes, history, and log sync&#xa;stores winner summary, latest status text, and completed turns" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eef6ff;strokeColor=#335c85;fontSize=13;fontColor=#111111;align=left;verticalAlign=top;spacingTop=10;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="650" width="400" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="enginesBox" value="MoveResolver + SolverEngine&#xa;resolve human result boards, drive computer turns, power the solver CLI, and audit self-play&#xa;CandidateGenerator, AnchorFinder, CrossCheckCache, and Rack support solver search&#xa;return ResolvedPlay and SolverResult using the same legality and scoring path" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f7f3e8;strokeColor=#6b5f3a;fontSize=13;fontColor=#111111;align=left;verticalAlign=top;spacingTop=10;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1060" y="190" width="480" height="250" as="geometry"/>
        </mxCell>
        <mxCell id="sharedRules" value="Shared board and rule classes&#xa;Board, MoveApplicator, WordFinder, LegalityChecker, and Scorer&#xa;PlayedTile, WordPlacement, MoveCandidate, SolverCase, and SolverResult&#xa;shared by the scorer, solver, JavaFX game, and self-play harness" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f7f3e8;strokeColor=#6b5f3a;fontSize=13;fontColor=#111111;align=left;verticalAlign=top;spacingTop=10;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1060" y="510" width="480" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="dictBox" value="Dictionary + Trie&#xa;load from the filesystem or bundled classpath resources&#xa;support full-word lookup, prefix lookup, and incremental trie walks" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f7f3e8;strokeColor=#6b5f3a;fontSize=13;fontColor=#111111;align=left;verticalAlign=top;spacingTop=10;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1060" y="760" width="480" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="outputsBox" value="Outputs&#xa;JavaFX board, rack, scores, status text, and turn history&#xa;Scorechecker legality and score text output&#xa;Solver best-move line and solution board" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#faf1eb;strokeColor=#7a4d33;fontSize=13;fontColor=#111111;align=left;verticalAlign=top;spacingTop=10;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1640" y="190" width="500" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="logBox" value="GameLogWriter&#xa;writes the initial state, each completed turn, and the winner summary&#xa;logs stay local under ignored game-logs/" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#faf1eb;strokeColor=#7a4d33;fontSize=13;fontColor=#111111;align=left;verticalAlign=top;spacingTop=10;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1640" y="430" width="500" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="packageBox" value="Packaging and resources&#xa;Scrabble.jar uses Main-Class: Scrabble&#xa;bundles Resources/config, Resources/dictionaries, and example assets&#xa;the jar runs outside the repo with bundled board and dictionary loading" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#faf1eb;strokeColor=#7a4d33;fontSize=13;fontColor=#111111;align=left;verticalAlign=top;spacingTop=10;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1640" y="760" width="500" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="verifyBox" value="Validation&#xa;regression suites pass&#xa;large self-play batches completed cleanly&#xa;the exchange-loop edge case is covered by a regression test&#xa;used to confirm the current backend and packaging behavior" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#faf1eb;strokeColor=#7a4d33;fontSize=13;fontColor=#111111;align=left;verticalAlign=top;spacingTop=10;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1640" y="960" width="500" height="170" as="geometry"/>
        </mxCell>


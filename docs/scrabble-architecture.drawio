          <mxGeometry x="1690" y="250" width="250" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="candidateGenerator" value="CandidateGenerator&#xa;anchor-based search over board segments&#xa;trie-backed word extension&#xa;cross-check pruning for perpendicular words&#xa;full-list and best-only generation paths" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontSize=13;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="1070" y="470" width="350" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="anchorRack" value="AnchorFinder + Rack&#xa;center anchor on empty board&#xa;adjacent anchors otherwise&#xa;mutable rack with blanks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontSize=13;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="1490" y="470" width="240" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="crossCheck" value="CrossCheckCache&#xa;precomputes allowed letters for empty squares&#xa;filters invalid cross words early" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontSize=13;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="1780" y="470" width="250" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="sharedReuse" value="Shared Validation + Scoring Reuse&#xa;CandidateGenerator reuses MoveApplicator, WordFinder, LegalityChecker, and Scorer&#xa;legal candidates are scored the same way as the scorer program&#xa;if scores tie, the first highest-scoring move encountered wins" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontSize=13;fontColor=#111111;" vertex="1" parent="1">

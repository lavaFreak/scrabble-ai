        </mxCell>

        <mxCell id="scoreJar" value="Scorechecker.jar&#xa;CLI entry point&#xa;reads original/result boards until EOF&#xa;prints exact scorer output format" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontSize=13;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="70" y="110" width="260" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="solverJar" value="Solver.jar&#xa;CLI entry point&#xa;reads board + tray until EOF&#xa;prints best move and solution board" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontSize=13;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="350" y="110" width="260" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="dictionary" value="Dictionary + Trie&#xa;Dictionary.fromFile(...) loads once per run&#xa;full-word lookup, prefix lookup, incremental cursor walk" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontSize=13;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="970" y="35" width="360" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="models" value="Shared Models&#xa;Board, PlayedTile, WordPlacement, MoveCandidate,&#xa;SolverCase, SolverResult&#xa;Board preserves premium squares and uppercase blanks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontSize=13;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="1380" y="35" width="520" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="boardParser" value="BoardParser&#xa;reads square board snapshots&#xa;shared by scorer and solver input" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontSize=13;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="110" y="250" width="240" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="compatibility" value="CompatibilityChecker&#xa;rejects removed or changed tiles&#xa;rejects multiplier mismatches" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontSize=13;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="390" y="250" width="250" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="moveExtractor" value="MoveExtractor&#xa;collects newly played tiles&#xa;formats coordinate output" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontSize=13;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="690" y="250" width="200" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="wordFinder" value="WordFinder&#xa;materializes main and cross words&#xa;from newly placed tiles" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontSize=13;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="110" y="470" width="240" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="legality" value="LegalityChecker&#xa;line and contiguity checks&#xa;center or touch rules&#xa;dictionary validation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontSize=13;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="390" y="470" width="250" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="scorer" value="Scorer&#xa;letter and word premiums&#xa;cross-word totals&#xa;50-point bingo bonus" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontSize=13;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="690" y="470" width="200" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="scoreOutput" value="Scorechecker Output&#xa;prints original board, result board, move coordinates, legality, and score&#xa;covered by example-output and synthetic regression tests" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontSize=13;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="220" y="720" width="500" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="solverInput" value="SolverInputParser&#xa;BoardParser + tray normalization&#xa;reads repeated cases until EOF" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontSize=13;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="1050" y="250" width="260" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="solverEngine" value="SolverEngine&#xa;asks CandidateGenerator for the best legal move&#xa;applies it to produce SolverResult" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111111;fontSize=13;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="1360" y="250" width="270" height="90" as="geometry"/>
        </mxCell>
